{
  "name": "iot-ayuda",
  "version": "2.0.0",
  "private": true,
  "description": "Sistema multi-sitio de monitoreo de aforo turístico",
  "scripts": {
    "start": "npm start --prefix backend",
    "dev:backend": "npm start --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "db:seed": "npm run db:seed --prefix backend",
    "db:add-sitios": "npm run db:add-sitios --prefix backend",
    "db:migrar-seguridad": "npm run db:migrar-seguridad --prefix backend",
    "db:migrate-stats": "npm run db:migrate-stats --prefix backend"
  }
}
